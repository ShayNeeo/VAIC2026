{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/contracts/intent-result/2.0.0",
  "title": "IntentResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "primary_intent",
    "sub_intents",
    "user_goal",
    "entities",
    "resolved_slots",
    "missing_information",
    "ambiguities",
    "evidence_spans",
    "field_confidence",
    "overall_confidence",
    "recommended_action"
  ],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "primary_intent": {"type": "string", "minLength": 1},
    "sub_intents": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "user_goal": {"type": "string", "minLength": 1},
    "entities": {"type": "object", "additionalProperties": true},
    "resolved_slots": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/resolvedValue"}
    },
    "constraints": {"type": "array", "items": {"type": "string"}, "default": []},
    "success_criteria": {"type": "array", "items": {"type": "string"}, "default": []},
    "missing_information": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "ambiguities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "hypotheses", "decision_impact"],
        "properties": {
          "field": {"type": "string"},
          "hypotheses": {"type": "array", "items": {"type": "string"}, "minItems": 2},
          "decision_impact": {"enum": ["none", "low", "medium", "high"]}
        }
      }
    },
    "evidence_spans": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "text", "message_id"],
        "properties": {
          "field": {"type": "string"},
          "text": {"type": "string"},
          "message_id": {"type": "string"}
        }
      }
    },
    "field_confidence": {
      "type": "object",
      "additionalProperties": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "overall_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "recommended_action": {
      "enum": ["continue_workflow", "call_context_tool", "defer_missing_field", "ask_clarification", "request_confirmation", "reject_out_of_scope", "escalate_human"]
    }
  },
  "$defs": {
    "resolvedValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "source_type", "source_id", "confidence", "confirmed", "observed_at"],
      "properties": {
        "value": {},
        "source_type": {"enum": ["user_explicit", "workspace", "sso", "iam", "crm", "document", "workflow", "conversation_confirmed", "cache", "llm_inference"]},
        "source_id": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "confirmed": {"type": "boolean"},
        "observed_at": {"type": "string", "format": "date-time"},
        "expires_at": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
