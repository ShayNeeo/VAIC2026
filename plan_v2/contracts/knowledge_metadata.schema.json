{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/contracts/knowledge-metadata/1.0.0",
  "title": "Evidence-grade Knowledge Metadata",
  "oneOf": [
    {"$ref": "#/$defs/sourceMetadata"},
    {"$ref": "#/$defs/documentMetadata"},
    {"$ref": "#/$defs/chunkMetadata"},
    {"$ref": "#/$defs/retrievalMetadata"},
    {"$ref": "#/$defs/claimEvidenceMetadata"},
    {"$ref": "#/$defs/agentRunMetadata"}
  ],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-fA-F0-9]{64}$"},
    "authorityTier": {"enum": ["A_INTERNAL", "A_OFFICIAL", "B_LICENSED", "C_OPEN", "D_DERIVED", "E_SYNTHETIC"]},
    "decisionRole": {"enum": ["AUTHORITATIVE", "VERIFICATION", "ENRICHMENT", "DISCOVERY", "EVALUATION_ONLY"]},
    "accessScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branches", "roles"],
      "properties": {
        "branches": {"type": "array", "items": {"type": "string"}},
        "roles": {"type": "array", "items": {"type": "string"}},
        "customer_ids": {"type": "array", "items": {"type": "string"}}
      }
    },
    "sourceMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "source_id", "source_name", "authority_tier", "decision_role", "business_owner", "data_steward", "approval_reference", "allowed_uses", "prohibited_uses", "sensitivity", "residency", "retention", "update_cadence", "max_age_seconds", "stale_behavior", "dataset_version", "source_hash", "quality_report_ref", "lifecycle_status"],
      "properties": {
        "metadata_type": {"const": "source"},
        "schema_version": {"const": "1.0.0"},
        "source_id": {"type": "string"},
        "source_name": {"type": "string"},
        "authority_tier": {"$ref": "#/$defs/authorityTier"},
        "decision_role": {"$ref": "#/$defs/decisionRole"},
        "business_owner": {"type": "string"},
        "data_steward": {"type": "string"},
        "approval_reference": {"type": "string"},
        "allowed_uses": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "prohibited_uses": {"type": "array", "items": {"type": "string"}},
        "sensitivity": {"type": "string"},
        "residency": {"type": "string"},
        "retention": {"type": "string"},
        "update_cadence": {"type": "string"},
        "max_age_seconds": {"type": "integer", "minimum": 0},
        "stale_behavior": {"enum": ["ALLOW_WITH_WARNING", "BLOCK_DECISION", "FAIL_CLOSED", "MANUAL_REVIEW"]},
        "dataset_version": {"type": "string"},
        "source_hash": {"$ref": "#/$defs/sha256"},
        "quality_report_ref": {"type": "string"},
        "lifecycle_status": {"type": "string"},
        "synthetic_flag": {"type": "boolean"}
      }
    },
    "documentMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "document_id", "source_id", "title", "document_type", "document_version", "effective_from", "lifecycle_status", "language", "file_hash", "parser_name", "parser_version", "extraction_quality", "ingestion_run_id", "indexed_at", "access_scope", "sensitivity", "synthetic_flag"],
      "properties": {
        "metadata_type": {"const": "document"},
        "schema_version": {"const": "1.0.0"},
        "document_id": {"type": "string"},
        "source_id": {"type": "string"},
        "title": {"type": "string"},
        "document_type": {"type": "string"},
        "document_version": {"type": "string"},
        "publication_date": {"type": ["string", "null"], "format": "date"},
        "effective_from": {"type": "string", "format": "date"},
        "effective_to": {"type": ["string", "null"], "format": "date"},
        "lifecycle_status": {"type": "string"},
        "language": {"type": "string"},
        "jurisdiction": {"type": ["string", "null"]},
        "audience": {"type": "array", "items": {"type": "string"}},
        "product_ids": {"type": "array", "items": {"type": "string"}},
        "policy_ids": {"type": "array", "items": {"type": "string"}},
        "workflow_ids": {"type": "array", "items": {"type": "string"}},
        "file_name": {"type": ["string", "null"]},
        "mime_type": {"type": ["string", "null"]},
        "file_hash": {"$ref": "#/$defs/sha256"},
        "parser_name": {"type": "string"},
        "parser_version": {"type": "string"},
        "extraction_quality": {"type": "number", "minimum": 0, "maximum": 1},
        "ingestion_run_id": {"type": "string"},
        "indexed_at": {"type": "string", "format": "date-time"},
        "access_scope": {"$ref": "#/$defs/accessScope"},
        "sensitivity": {"type": "string"},
        "synthetic_flag": {"type": "boolean"}
      }
    },
    "chunkMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "chunk_id", "document_id", "document_version", "source_id", "section_path", "chunk_type", "language", "effective_from", "active", "access_scope", "content_hash", "embedding_model", "embedding_version", "embedding_dimension", "chunking_strategy", "chunking_version", "synthetic_flag", "data_disclaimer"],
      "properties": {
        "metadata_type": {"const": "chunk"},
        "schema_version": {"const": "1.0.0"},
        "chunk_id": {"type": "string"},
        "document_id": {"type": "string"},
        "document_version": {"type": "string"},
        "source_id": {"type": "string"},
        "parent_chunk_id": {"type": ["string", "null"]},
        "previous_chunk_id": {"type": ["string", "null"]},
        "next_chunk_id": {"type": ["string", "null"]},
        "section_path": {"type": "string"},
        "page_number": {"type": ["integer", "null"], "minimum": 1},
        "line_start": {"type": ["integer", "null"], "minimum": 1},
        "line_end": {"type": ["integer", "null"], "minimum": 1},
        "sheet_name": {"type": ["string", "null"]},
        "table_id": {"type": ["string", "null"]},
        "row_key": {"type": ["string", "null"]},
        "header_context": {"type": ["string", "null"]},
        "chunk_type": {"type": "string"},
        "language": {"type": "string"},
        "product_ids": {"type": "array", "items": {"type": "string"}},
        "rule_ids": {"type": "array", "items": {"type": "string"}},
        "workflow_ids": {"type": "array", "items": {"type": "string"}},
        "effective_from": {"type": "string", "format": "date"},
        "effective_to": {"type": ["string", "null"], "format": "date"},
        "active": {"type": "boolean"},
        "superseded_by": {"type": ["string", "null"]},
        "access_scope": {"$ref": "#/$defs/accessScope"},
        "segments": {"type": "array", "items": {"type": "string"}},
        "industries": {"type": "array", "items": {"type": "string"}},
        "content_hash": {"$ref": "#/$defs/sha256"},
        "embedding_model": {"type": "string"},
        "embedding_version": {"type": "string"},
        "embedding_dimension": {"type": "integer", "minimum": 1},
        "chunking_strategy": {"type": "string"},
        "chunking_version": {"type": "string"},
        "synthetic_flag": {"type": "boolean"},
        "data_disclaimer": {"type": "string"}
      }
    },
    "retrievalMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "query_id", "trace_id", "task_id", "agent_type", "tool_name", "query_hash", "query_rewrite_version", "metadata_filters", "acl_decision", "effective_at", "candidates", "threshold", "index_version", "embedding_version", "retrieval_policy_version", "latency_ms", "degraded_mode"],
      "properties": {
        "metadata_type": {"const": "retrieval"},
        "schema_version": {"const": "1.0.0"},
        "query_id": {"type": "string"},
        "trace_id": {"type": "string"},
        "task_id": {"type": "string"},
        "agent_type": {"type": "string"},
        "tool_name": {"type": "string"},
        "query_hash": {"$ref": "#/$defs/sha256"},
        "query_rewrite_version": {"type": "string"},
        "metadata_filters": {"type": "object"},
        "acl_decision": {"enum": ["allowed", "filtered", "denied"]},
        "effective_at": {"type": "string", "format": "date-time"},
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["chunk_id", "dense_score", "sparse_score", "fusion_score", "rerank_score", "final_rank", "selected", "decision_reason"],
            "properties": {
              "chunk_id": {"type": "string"},
              "dense_score": {"type": "number"},
              "sparse_score": {"type": "number"},
              "fusion_score": {"type": "number"},
              "rerank_score": {"type": "number"},
              "final_rank": {"type": "integer", "minimum": 1},
              "selected": {"type": "boolean"},
              "decision_reason": {"type": "string"}
            }
          }
        },
        "threshold": {"type": "number"},
        "index_version": {"type": "string"},
        "embedding_version": {"type": "string"},
        "retrieval_policy_version": {"type": "string"},
        "latency_ms": {"type": "integer", "minimum": 0},
        "degraded_mode": {"type": "boolean"},
        "empty_reason": {"type": ["string", "null"]}
      }
    },
    "claimEvidenceMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "claim_id", "finding_id", "agent_type", "claim_type", "claim_text_sanitized", "support_status", "evidence_refs", "validation_method", "evidence_coverage", "contradiction_refs", "validator_version", "validated_at", "review_status"],
      "properties": {
        "metadata_type": {"const": "claim_evidence"},
        "schema_version": {"const": "1.0.0"},
        "claim_id": {"type": "string"},
        "finding_id": {"type": "string"},
        "agent_type": {"type": "string"},
        "claim_type": {"type": "string"},
        "claim_text_sanitized": {"type": "string"},
        "support_status": {"enum": ["supported", "partially_supported", "contradicted", "stale", "unauthorized", "missing"]},
        "evidence_refs": {"type": "array", "items": {"type": "object"}},
        "validation_method": {"enum": ["exact", "deterministic_rule", "semantic", "human"]},
        "evidence_coverage": {"type": "number", "minimum": 0, "maximum": 1},
        "contradiction_refs": {"type": "array", "items": {"type": "string"}},
        "validator_version": {"type": "string"},
        "validated_at": {"type": "string", "format": "date-time"},
        "review_status": {"enum": ["not_required", "pending", "confirmed", "rejected"]}
      }
    },
    "agentRunMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadata_type", "schema_version", "agent_run_id", "case_id", "trace_id", "agent_type", "agent_manifest_version", "task_id", "task_type", "input_artifact_hash", "output_artifact_hash", "model_provider", "model_name", "prompt_version", "output_schema_version", "tool_policy_version", "tools_called", "denied_tool_calls", "started_at", "completed_at", "latency_ms", "fallback_used", "retry_count", "stop_reason", "revision"],
      "properties": {
        "metadata_type": {"const": "agent_run"},
        "schema_version": {"const": "1.0.0"},
        "agent_run_id": {"type": "string"},
        "case_id": {"type": "string"},
        "trace_id": {"type": "string"},
        "agent_type": {"type": "string"},
        "agent_manifest_version": {"type": "string"},
        "task_id": {"type": "string"},
        "task_type": {"type": "string"},
        "input_artifact_hash": {"$ref": "#/$defs/sha256"},
        "output_artifact_hash": {"$ref": "#/$defs/sha256"},
        "model_provider": {"type": "string"},
        "model_name": {"type": "string"},
        "prompt_version": {"type": "string"},
        "output_schema_version": {"type": "string"},
        "tool_policy_version": {"type": "string"},
        "tools_called": {"type": "array", "items": {"type": "string"}},
        "denied_tool_calls": {"type": "array", "items": {"type": "string"}},
        "started_at": {"type": "string", "format": "date-time"},
        "completed_at": {"type": "string", "format": "date-time"},
        "latency_ms": {"type": "integer", "minimum": 0},
        "token_usage": {"type": ["object", "null"]},
        "estimated_cost": {"type": ["number", "null"], "minimum": 0},
        "fallback_used": {"type": "boolean"},
        "retry_count": {"type": "integer", "minimum": 0},
        "stop_reason": {"type": "string"},
        "revision": {"type": "integer", "minimum": 1, "maximum": 3},
        "parent_finding_id": {"type": ["string", "null"]},
        "assistance_request_ids": {"type": "array", "items": {"type": "string"}},
        "conflict_ids": {"type": "array", "items": {"type": "string"}},
        "convergence_hash": {"type": ["string", "null"]}
      }
    }
  }
}
