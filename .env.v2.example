APP_ENV=development
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# V2 local persistent stores
V2_DB_PATH=./data/state/v2.sqlite3
VECTOR_DB_DIR=./data/vector_db
AUDIT_LOG_PATH=./data/logs/audit.jsonl

# Replace in pilot/production; startup fails with demo secret outside development.
APPROVAL_SECRET=replace-with-a-long-random-secret
APPROVAL_TOKEN_TTL_SECONDS=300

# Local dashboard login only; replace with enterprise SSO/IAM in pilot.
DEMO_LOGIN_PASSWORD=demo1234
AUTH_SECRET=replace-with-a-long-random-auth-secret
AUTH_TOKEN_TTL_SECONDS=28800

# --- LLM / intent extraction ---
# Offline deterministic is the default (no key required). Enable only with a
# configured provider -- see app/intent/extractor.py.
INTENT_USE_LLM=false
MODEL_TIMEOUT_SECONDS=15
MAX_UPLOAD_BYTES=10485760
DEFAULT_LLM=openai
# openai | google | ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# --- Knowledge/product-legal embedding provider (app/knowledge/index.py) ---
# openai | gemini. Default is openai: verified live that the Gemini project
# behind GOOGLE_API_KEY can run out of prepayment credits (429
# RESOURCE_EXHAUSTED), which silently breaks product retrieval if left as
# the default. See docs/RAG_PROVIDER_AND_FALLBACK.md.
KNOWLEDGE_EMBEDDING_PROVIDER=openai

# --- RAG provider routing (app/config.py, app/knowledge/rag_provider.py) ---
# local | mcp | hybrid. "local" is the safe default when no MCP server has
# been deployed -- it never attempts an MCP connection or health check.
# RAG_MCP_ENABLED below is a deprecated alias kept only for old .env files;
# RAG_PROVIDER always takes priority when both are set. See
# docs/RAG_PROVIDER_AND_FALLBACK.md for the full local/mcp/hybrid contract.
RAG_PROVIDER=local
# RAG_MCP_ENABLED=true

# Circuit breaker guarding the MCP path in hybrid mode.
RAG_MCP_FAILURE_THRESHOLD=3
RAG_MCP_COOLDOWN_SECONDS=30
RAG_MCP_REQUEST_TIMEOUT_SECONDS=3
RAG_MCP_HALF_OPEN_MAX_CALLS=1
RAG_MCP_WARNING_COOLDOWN_SECONDS=30

# app/knowledge/service.py / legal_service.py -> the standalone RAG MCP
# server's product/legal domain endpoints (only used when RAG_PROVIDER is
# mcp or hybrid).
RAG_MCP_PRODUCT_URL=http://localhost:8100/mcp/product
RAG_MCP_PRODUCT_TOKEN=local-rag-mcp-change-me-product
RAG_MCP_LEGAL_URL=http://localhost:8100/mcp/legal
RAG_MCP_LEGAL_TOKEN=local-rag-mcp-change-me-legal

# --- Independent RAG MCP server process (services/rag_mcp/, sandbox
# service-to-service auth). Only relevant if you actually run
# `python -m services.rag_mcp.server` / run_rag_mcp.cmd. ---
RAG_MCP_HOST=127.0.0.1
RAG_MCP_PORT=8100
RAG_MCP_URL=http://127.0.0.1:8100/mcp
RAG_MCP_DB_PATH=./data/rag_mcp/rag.sqlite3
RAG_MCP_SERVICE_TOKEN=local-rag-mcp-change-me
RAG_MCP_OPERATIONS_TOKEN=local-rag-mcp-change-me-operations
RAG_MCP_EVIDENCE_TOKEN=local-rag-mcp-change-me-evidence
RAG_MCP_REQUIRE_AUTH=true
RAG_MCP_EMBEDDING_PROVIDER=openai
RAG_MCP_TOP_K=5
RAG_MCP_THRESHOLD=0.12
RAG_MCP_MAX_CONTEXT_CHARS=8000
