# === LLM (Google AI Studio / Gemini) ===
GOOGLE_API_KEY=your-google-ai-studio-api-key
GOOGLE_MODEL=gemma-4-31b-it
GOOGLE_ENDPOINT=https://generativelanguage.googleapis.com

# === VPS / SSH (IPv6 only; IPv4 via NAT SSH) ===
VPS_HOST=sgp1.w9.nu
VPS_PORT=2204
VPS_USER=root
VPS_SSH_PORT=2204
VPS_IPV6=

# === MCP server ports (one per agent) ===
PRODUCT_AGENT_PORT=8004
LEGAL_AGENT_PORT=8005
OPERATIONS_AGENT_PORT=8006
APPROVAL_AGENT_PORT=8007

# === Network binding (IPv6 dual-stack) ===
BIND_HOST=::

# === App (FastAPI orchestrator) ===
APPROVAL_SECRET=replace-with-a-long-random-secret
APPROVAL_TOKEN_TTL_SECONDS=300
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# === RAG settings ===
RAG_DENSE_WEIGHT=0.6
RAG_SPARSE_WEIGHT=0.4
RAG_THRESHOLD=0.35
RAG_TOP_K=5

# === LLM Client ===
LLM_TIMEOUT_SECONDS=5.0
LLM_MAX_RETRIES=1
LLM_MAX_OUTPUT_TOKENS=256

# === Embedding (phase 2) ===
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=128
USE_REAL_EMBEDDING=false

# === Feature flags ===
USE_GEMMA_FOR_GUARDRAILS=true
USE_GEMMA_FOR_VERIFY=true
USE_GEMMA_FOR_REASON=true
EVIDENCE_SEMANTIC_THRESHOLD=0.6